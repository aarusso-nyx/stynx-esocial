{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.sistematech.local/esocial/v1/esocial-s-1200-sgp-request-dto-v1.schema.json",
  "title": "eSocial S-1200 SGP request DTO v1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "eventClass": {
      "const": "S-1200"
    },
    "tenantId": {
      "type": "string",
      "minLength": 1
    },
    "sourceEventId": {
      "type": "string",
      "minLength": 1
    },
    "sourceEntityId": {
      "type": "string",
      "minLength": 1
    },
    "sourceEntityIds": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "environment": {
      "enum": [
        "qualification",
        "restricted_production",
        "production"
      ]
    },
    "operation": {
      "enum": [
        "inclusion",
        "change",
        "rectification",
        "exclusion"
      ]
    },
    "employerCnpj": {
      "type": "string",
      "minLength": 1
    },
    "competence": {
      "type": "string",
      "minLength": 1
    },
    "payrollRunId": {
      "type": "string",
      "minLength": 1
    },
    "payrollRunStatus": {
      "type": "string",
      "minLength": 1
    },
    "workers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "employeeId": {
            "type": "string",
            "minLength": 1
          },
          "cpf": {
            "type": "string",
            "minLength": 1
          },
          "registration": {
            "type": "string",
            "minLength": 1
          },
          "categoryCode": {
            "type": "string",
            "minLength": 1
          },
          "establishmentRegistrationNumber": {
            "type": "string",
            "minLength": 1
          },
          "lotationCode": {
            "type": "string",
            "minLength": 1
          },
          "rubrics": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "rubricCode": {
                  "type": "string",
                  "minLength": 1
                },
                "rubricTableId": {
                  "type": "string",
                  "minLength": 1
                },
                "ideDmDev": {
                  "type": "string",
                  "minLength": 1
                },
                "amount": {
                  "type": "number"
                },
                "quantity": {
                  "type": "number"
                }
              },
              "required": [
                "rubricCode",
                "ideDmDev",
                "amount"
              ]
            }
          }
        },
        "required": [
          "employeeId",
          "cpf",
          "registration",
          "categoryCode",
          "rubrics"
        ]
      }
    }
  },
  "required": [
    "eventClass",
    "tenantId",
    "sourceEventId",
    "employerCnpj",
    "competence",
    "payrollRunId",
    "payrollRunStatus",
    "workers"
  ],
  "not": {
    "anyOf": [
      {
        "required": [
          "xml"
        ]
      },
      {
        "required": [
          "payloadXml"
        ]
      },
      {
        "required": [
          "signedXml"
        ]
      },
      {
        "required": [
          "signedEnvelope"
        ]
      },
      {
        "required": [
          "pkcs7"
        ]
      },
      {
        "required": [
          "pkcs7Sha256"
        ]
      }
    ]
  }
}
