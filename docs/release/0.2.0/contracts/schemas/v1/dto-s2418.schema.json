{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.sistematech.local/esocial/v1/esocial-s-2418-sgp-request-dto-v1.schema.json",
  "title": "eSocial S-2418 SGP request DTO v1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "eventClass": {
      "const": "S-2418"
    },
    "tenantId": {
      "type": "string",
      "minLength": 1
    },
    "sourceEventId": {
      "type": "string",
      "minLength": 1
    },
    "sourceEntityId": {
      "type": "string",
      "minLength": 1
    },
    "sourceEntityIds": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "environment": {
      "enum": [
        "qualification",
        "restricted_production",
        "production"
      ]
    },
    "operation": {
      "enum": [
        "inclusion",
        "change",
        "rectification",
        "exclusion"
      ]
    },
    "employerCnpj": {
      "type": "string",
      "minLength": 1
    },
    "employerCpf": {
      "type": "string",
      "minLength": 1
    },
    "eventId": {
      "type": "string",
      "minLength": 1
    },
    "benefitKind": {
      "enum": [
        "RETIREMENT",
        "PENSION"
      ]
    },
    "benefitIdentifier": {
      "type": "string",
      "minLength": 1
    },
    "beneficiaryCpf": {
      "type": "string",
      "minLength": 1
    },
    "benefitNumber": {
      "type": "string",
      "minLength": 1
    },
    "effectiveReactivationDate": {
      "type": "string",
      "minLength": 1
    },
    "financialEffectDate": {
      "type": "string",
      "minLength": 1
    },
    "acceptedS2410Receipt": {
      "type": "string",
      "minLength": 1
    },
    "suspendedOrTerminatedBenefitReceipt": {
      "type": "string",
      "minLength": 1
    },
    "reactivatedBenefitReceipt": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "eventClass",
    "tenantId",
    "sourceEventId",
    "employerCnpj",
    "benefitKind",
    "benefitIdentifier",
    "beneficiaryCpf",
    "benefitNumber",
    "effectiveReactivationDate",
    "financialEffectDate",
    "acceptedS2410Receipt",
    "suspendedOrTerminatedBenefitReceipt"
  ],
  "not": {
    "anyOf": [
      {
        "required": [
          "xml"
        ]
      },
      {
        "required": [
          "payloadXml"
        ]
      },
      {
        "required": [
          "signedXml"
        ]
      },
      {
        "required": [
          "signedEnvelope"
        ]
      },
      {
        "required": [
          "pkcs7"
        ]
      },
      {
        "required": [
          "pkcs7Sha256"
        ]
      }
    ]
  }
}
