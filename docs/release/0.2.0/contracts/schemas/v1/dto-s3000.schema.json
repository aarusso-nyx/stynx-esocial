{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.sistematech.local/esocial/v1/esocial-s-3000-sgp-request-dto-v1.schema.json",
  "title": "eSocial S-3000 SGP request DTO v1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "eventClass": {
      "const": "S-3000"
    },
    "tenantId": {
      "type": "string",
      "minLength": 1
    },
    "sourceEventId": {
      "type": "string",
      "minLength": 1
    },
    "sourceEntityId": {
      "type": "string",
      "minLength": 1
    },
    "sourceEntityIds": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "environment": {
      "enum": [
        "qualification",
        "restricted_production",
        "production"
      ]
    },
    "operation": {
      "enum": [
        "inclusion",
        "change",
        "rectification",
        "exclusion"
      ]
    },
    "employerCnpj": {
      "type": "string",
      "minLength": 1
    },
    "employerCpf": {
      "type": "string",
      "minLength": 1
    },
    "eventId": {
      "type": "string",
      "minLength": 1
    },
    "originalEventClass": {
      "type": "string",
      "minLength": 1
    },
    "originalReceipt": {
      "type": "string",
      "minLength": 1
    },
    "exclusionReason": {
      "type": "string",
      "minLength": 1
    },
    "originalCompetence": {
      "type": "string",
      "minLength": 1
    },
    "cpf": {
      "type": "string",
      "minLength": 1
    },
    "registration": {
      "type": "string",
      "minLength": 1
    },
    "beneficiaryCpf": {
      "type": "string",
      "minLength": 1
    },
    "benefitNumber": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "eventClass",
    "tenantId",
    "sourceEventId",
    "employerCnpj",
    "originalEventClass",
    "originalReceipt",
    "exclusionReason"
  ],
  "not": {
    "anyOf": [
      {
        "required": [
          "xml"
        ]
      },
      {
        "required": [
          "payloadXml"
        ]
      },
      {
        "required": [
          "signedXml"
        ]
      },
      {
        "required": [
          "signedEnvelope"
        ]
      },
      {
        "required": [
          "pkcs7"
        ]
      },
      {
        "required": [
          "pkcs7Sha256"
        ]
      }
    ]
  }
}
