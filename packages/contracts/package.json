{
  "name": "@esocial/contracts",
  "version": "1.1.0-rc.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "schemas",
    "examples",
    "openapi.yaml",
    "asyncapi.yaml",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schemas/v1/*.schema.json": "./schemas/v1/*.schema.json",
    "./examples/v1/requests/*.json": "./examples/v1/requests/*.json"
  },
  "scripts": {
    "build": "tsc -b && npm run schemas:generate",
    "schemas:generate": "node src/schema-generation/write-schemas.mjs",
    "specs:check": "node src/spec-generation/check-specs.mjs"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://registry.npmjs.org/",
    "tag": "v1"
  }
}
