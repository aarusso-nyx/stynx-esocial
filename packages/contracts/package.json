{
  "name": "@esocial/contracts",
  "version": "1.0.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "schemas",
    "examples",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schemas/v1/*.schema.json": "./schemas/v1/*.schema.json",
    "./examples/v1/requests/*.json": "./examples/v1/requests/*.json"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://registry.npmjs.org/",
    "tag": "v1"
  }
}
