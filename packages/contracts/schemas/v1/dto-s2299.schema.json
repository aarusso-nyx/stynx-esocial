{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.sistematech.local/esocial/v1/esocial-s-2299-sgp-request-dto-v1.schema.json",
  "title": "eSocial S-2299 SGP request DTO v1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "eventClass": {
      "const": "S-2299"
    },
    "tenantId": {
      "type": "string",
      "minLength": 1
    },
    "sourceEventId": {
      "type": "string",
      "minLength": 1
    },
    "sourceEntityId": {
      "type": "string",
      "minLength": 1
    },
    "sourceEntityIds": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "environment": {
      "enum": [
        "qualification",
        "restricted_production",
        "production"
      ]
    },
    "operation": {
      "enum": [
        "inclusion",
        "change",
        "rectification",
        "exclusion"
      ]
    },
    "employerCnpj": {
      "type": "string",
      "minLength": 1
    },
    "employerCpf": {
      "type": "string",
      "minLength": 1
    },
    "eventId": {
      "type": "string",
      "minLength": 1
    },
    "employeeId": {
      "type": "string",
      "minLength": 1
    },
    "cpf": {
      "type": "string",
      "minLength": 1
    },
    "registration": {
      "type": "string",
      "minLength": 1
    },
    "receiptReference": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "enum": [
        "with-notice",
        "without-notice"
      ]
    },
    "terminationDate": {
      "type": "string",
      "minLength": 1
    },
    "terminationReasonCode": {
      "type": "string",
      "minLength": 1
    },
    "projectedNoticeEndDate": {
      "type": "string",
      "minLength": 1
    },
    "ideDmDev": {
      "type": "string",
      "minLength": 1
    },
    "establishmentRegistrationNumber": {
      "type": "string",
      "minLength": 1
    },
    "lotationCode": {
      "type": "string",
      "minLength": 1
    },
    "rubrics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "rubricCode": {
            "type": "string",
            "minLength": 1
          },
          "rubricTableId": {
            "type": "string",
            "minLength": 1
          },
          "quantity": {
            "anyOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "number"
              }
            ]
          },
          "amount": {
            "anyOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "number"
              }
            ]
          }
        },
        "required": [
          "rubricCode",
          "quantity",
          "amount"
        ]
      }
    }
  },
  "required": [
    "eventClass",
    "tenantId",
    "sourceEventId",
    "employerCnpj",
    "employeeId",
    "cpf",
    "registration",
    "kind",
    "terminationDate",
    "terminationReasonCode",
    "ideDmDev",
    "rubrics"
  ],
  "not": {
    "anyOf": [
      {
        "required": [
          "xml"
        ]
      },
      {
        "required": [
          "payloadXml"
        ]
      },
      {
        "required": [
          "signedXml"
        ]
      },
      {
        "required": [
          "signedEnvelope"
        ]
      },
      {
        "required": [
          "pkcs7"
        ]
      },
      {
        "required": [
          "pkcs7Sha256"
        ]
      }
    ]
  }
}
