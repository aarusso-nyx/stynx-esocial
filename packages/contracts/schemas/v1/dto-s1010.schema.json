{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.sistematech.local/esocial/v1/esocial-s-1010-sgp-request-dto-v1.schema.json",
  "title": "eSocial S-1010 SGP request DTO v1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "eventClass": {
      "const": "S-1010"
    },
    "tenantId": {
      "type": "string",
      "minLength": 1
    },
    "sourceEventId": {
      "type": "string",
      "minLength": 1
    },
    "sourceEntityId": {
      "type": "string",
      "minLength": 1
    },
    "sourceEntityIds": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "environment": {
      "enum": [
        "qualification",
        "restricted_production",
        "production"
      ]
    },
    "operation": {
      "enum": [
        "inclusion",
        "change",
        "rectification",
        "exclusion"
      ]
    },
    "employerCnpj": {
      "type": "string",
      "minLength": 1
    },
    "employerCpf": {
      "type": "string",
      "minLength": 1
    },
    "validityStart": {
      "type": "string",
      "minLength": 1
    },
    "validityEnd": {
      "type": "string",
      "minLength": 1
    },
    "rubricCode": {
      "type": "string",
      "minLength": 1
    },
    "rubricTableId": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "rubricType": {
      "type": "string",
      "minLength": 1
    },
    "natureCode": {
      "type": "string",
      "minLength": 1
    },
    "socialSecurityIncidence": {
      "type": "string",
      "minLength": 1
    },
    "incomeTaxIncidence": {
      "type": "string",
      "minLength": 1
    },
    "fgtsIncidence": {
      "type": "string",
      "minLength": 1
    },
    "unionContributionIncidence": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "eventClass",
    "tenantId",
    "sourceEventId",
    "employerCnpj",
    "validityStart",
    "rubricCode",
    "rubricTableId",
    "description",
    "rubricType",
    "natureCode",
    "socialSecurityIncidence",
    "incomeTaxIncidence",
    "fgtsIncidence"
  ],
  "not": {
    "anyOf": [
      {
        "required": [
          "xml"
        ]
      },
      {
        "required": [
          "payloadXml"
        ]
      },
      {
        "required": [
          "signedXml"
        ]
      },
      {
        "required": [
          "signedEnvelope"
        ]
      },
      {
        "required": [
          "pkcs7"
        ]
      },
      {
        "required": [
          "pkcs7Sha256"
        ]
      }
    ]
  }
}
