        },
        {
          "$ref": "./dto-s1200.schema.json"
        },
        {
          "$ref": "./dto-s1202.schema.json"
        },
        {
          "$ref": "./dto-s1207.schema.json"
        },
        {
          "$ref": "./dto-s1210.schema.json"
        },
        {
          "$ref": "./dto-s1298.schema.json"
        },
        {
          "$ref": "./dto-s1299.schema.json"
        },
        {
          "$ref": "./dto-s2200.schema.json"
        },
        {
          "$ref": "./dto-s2205.schema.json"
        },
        {
          "$ref": "./dto-s2206.schema.json"
        },
        {
          "$ref": "./dto-s2210.schema.json"
        },
        {
          "$ref": "./dto-s2220.schema.json"
        },
        {
          "$ref": "./dto-s2230.schema.json"
        },
        {
          "$ref": "./dto-s2240.schema.json"
        },
        {
          "$ref": "./dto-s2298.schema.json"
        },
        {
          "$ref": "./dto-s2299.schema.json"
        },
        {
          "$ref": "./dto-s2300.schema.json"
        },
        {
          "$ref": "./dto-s2306.schema.json"
        },
        {
          "$ref": "./dto-s2399.schema.json"
        },
        {
          "$ref": "./dto-s2400.schema.json"
        },
        {
          "$ref": "./dto-s2405.schema.json"
        },
        {
          "$ref": "./dto-s2410.schema.json"
        },
        {
          "$ref": "./dto-s2416.schema.json"
        },
        {
          "$ref": "./dto-s2418.schema.json"
        },
        {
          "$ref": "./dto-s2420.schema.json"
        },
        {
          "$ref": "./dto-s2501.schema.json"
        },
        {
          "$ref": "./dto-s3000.schema.json"
        },
        {
          "$ref": "./dto-s5001.schema.json"
        },
        {
          "$ref": "./dto-s5002.schema.json"
        },
        {
          "$ref": "./dto-s5011.schema.json"
        },
        {
          "$ref": "./dto-s5012.schema.json"
        },
        {
          "$ref": "./dto-s5013.schema.json"
        }
      ]
    }
  },
  "required": [
    "version",
    "family",
    "request-id",
    "correlation-id",
    "idempotency-key",
    "created_at",
    "tenant_id",
    "environment",
    "event_class",
    "source",
    "kind",
    "payload_hash",
    "attempt",
    "max-attempts",
    "reply-to",
    "dead-letter-topic",
    "payload"
  ]
}
