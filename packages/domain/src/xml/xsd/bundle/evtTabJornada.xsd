<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns="http://www.esocial.gov.br/schema/evt/evtTabJornada/v_S_01_03_00" targetNamespace="http://www.esocial.gov.br/schema/evt/evtTabJornada/v_S_01_03_00" xmlns:ds="http://www.w3.org/2000/09/xmldsig#" xmlns:xs="http://www.w3.org/2001/XMLSchema" elementFormDefault="qualified" attributeFormDefault="unqualified">
  <xs:include schemaLocation="tipos.xsd" />
  <xs:import namespace="http://www.w3.org/2000/09/xmldsig#" schemaLocation="xmldsig-core-schema.xsd" />
  <xs:element name="eSocial">
    <xs:complexType>
      <xs:sequence>
        <xs:element name="evtTabJornada">
          <xs:complexType>
            <xs:sequence>
              <xs:element name="ideEvento" type="T_ideEvento_evtTab" />
              <xs:element name="ideEmpregador" type="T_ideEmpregador" />
              <xs:element name="infoJornada">
                <xs:complexType>
                  <xs:sequence>
                    <xs:choice>
                      <xs:element name="inclusao">
                        <xs:complexType>
                          <xs:sequence>
                            <xs:element name="ideJornada" type="T_ideJornada" />
                            <xs:element name="dadosJornada" type="T_dadosJornada" />
                          </xs:sequence>
                        </xs:complexType>
                      </xs:element>
                      <xs:element name="alteracao">
                        <xs:complexType>
                          <xs:sequence>
                            <xs:element name="ideJornada" type="T_ideJornada" />
                            <xs:element name="dadosJornada" type="T_dadosJornada" />
                            <xs:element name="novaValidade" minOccurs="0" type="T_novaValidade" />
                          </xs:sequence>
                        </xs:complexType>
                      </xs:element>
                      <xs:element name="exclusao">
                        <xs:complexType>
                          <xs:sequence>
                            <xs:element name="ideJornada" type="T_ideJornada" />
                          </xs:sequence>
                        </xs:complexType>
                      </xs:element>
                    </xs:choice>
                  </xs:sequence>
                </xs:complexType>
              </xs:element>
            </xs:sequence>
            <xs:attribute name="Id" use="required" type="TS_Id" />
          </xs:complexType>
        </xs:element>
        <xs:element ref="ds:Signature" />
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:complexType name="T_ideJornada">
    <xs:sequence>
      <xs:element name="codJornada" type="TS_codigo_esocial" />
      <xs:element name="iniValid" type="TS_iniValid" />
      <xs:element name="fimValid" minOccurs="0" type="TS_fimValid" />
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="T_dadosJornada">
    <xs:sequence>
      <xs:element name="dscJornada" type="TS_texto_100" />
      <xs:element name="durJornada" type="xs:duration" />
    </xs:sequence>
  </xs:complexType>
</xs:schema>
