{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "stynx-esocial dev isolated account skeleton",
  "Resources": {
    "EventsBus": {
      "Type": "AWS::Events::EventBus",
      "Properties": {
        "Name": "stynx-esocial-events"
      }
    },
    "SubmitRequestQueue": {
      "Type": "AWS::SQS::Queue",
      "Properties": {
        "QueueName": "sgp.esocial.submit.request.dev.fifo",
        "FifoQueue": true,
        "ContentBasedDeduplication": false
      }
    },
    "SubmitResponseQueue": {
      "Type": "AWS::SQS::Queue",
      "Properties": {
        "QueueName": "sgp.esocial.submit.response.dev.fifo",
        "FifoQueue": true,
        "ContentBasedDeduplication": false
      }
    },
    "SubmitDlq": {
      "Type": "AWS::SQS::Queue",
      "Properties": {
        "QueueName": "sgp.esocial.submit.dlq.dev.fifo",
        "FifoQueue": true
      }
    }
  }
}
