{
  "extends": "../../backend/tsconfig.json",
  "compilerOptions": {
    "baseUrl": "../..",
    "declaration": false,
    "module": "commonjs",
    "moduleResolution": "node",
    "resolvePackageJsonExports": false,
    "noEmit": true,
    "rootDir": "../..",
    "paths": {
      "*": ["backend/node_modules/*", "*"]
    },
    "typeRoots": ["../../backend/node_modules/@types"],
    "types": ["jest", "node"]
  },
  "include": ["**/*.ts"]
}
